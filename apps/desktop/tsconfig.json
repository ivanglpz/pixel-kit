{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@/db/*": ["../../src/db/*"],
      "@/editor": ["../../packages/editor/src/index.tsx"],
      "@/editor/*": ["../../packages/editor/src/*"],
      "@/jotai/*": ["../../src/jotai/*"],
      "@/pages/*": ["../../src/pages/*"],
      "@/services/*": ["../../src/services/*"],
      "@/utils/*": ["../../src/utils/*"],
      "@/*": ["./src/*"],
      "@stylespixelkit/*": ["../../styled-system/*"]
    }
  },
  "include": [
    "electron/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "next-env.d.ts"
  ]
}
